{
  "name": "@caya8205-2/capcay-llm",
  "version": "0.1.1",
  "description": "Lightweight unified LLM client for Node.js — Groq, Anthropic, OpenAI with one interface",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "pnpm build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/caya8205-2/capcay-llm.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "keywords": [
    "llm",
    "groq",
    "anthropic",
    "openai",
    "ai",
    "unified",
    "client"
  ],
  "author": "caya8205-2",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "groq-sdk": "latest",
    "openai": "^4.47.0"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "@types/node": "^20.12.0"
  }
}